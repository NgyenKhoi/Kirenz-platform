FROM node:22-alpine AS build
WORKDIR /app

ARG VITE_BASE_API_URL=http://localhost:8080/api
ARG VITE_API_BASE_URL=http://localhost:8080/api
ARG VITE_USER_SERVICE_BASE_URL=http://localhost:8080/api
ARG VITE_SOCIAL_SERVICE_BASE_URL=http://localhost:8080/api
ARG VITE_CHAT_API_URL=http://localhost:8080
ARG VITE_NOTIFICATION_API_URL=http://localhost:8080
ARG VITE_NOTIFICATION_SERVICE_BASE_URL=http://localhost:8080/api
ARG VITE_CHAT_WS_URL=http://localhost:8080/ws/chat
ARG VITE_NOTIFICATION_WS_URL=http://localhost:8080/ws/notifications

ENV VITE_BASE_API_URL=$VITE_BASE_API_URL
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
ENV VITE_USER_SERVICE_BASE_URL=$VITE_USER_SERVICE_BASE_URL
ENV VITE_SOCIAL_SERVICE_BASE_URL=$VITE_SOCIAL_SERVICE_BASE_URL
ENV VITE_CHAT_API_URL=$VITE_CHAT_API_URL
ENV VITE_NOTIFICATION_API_URL=$VITE_NOTIFICATION_API_URL
ENV VITE_NOTIFICATION_SERVICE_BASE_URL=$VITE_NOTIFICATION_SERVICE_BASE_URL
ENV VITE_CHAT_WS_URL=$VITE_CHAT_WS_URL
ENV VITE_NOTIFICATION_WS_URL=$VITE_NOTIFICATION_WS_URL

COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

FROM nginx:1.27-alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
